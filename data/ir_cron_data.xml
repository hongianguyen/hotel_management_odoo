<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data noupdate="1">
        <!-- Night Audit Cron Job: runs daily at 23:55 to close out the day -->
        <record id="ir_cron_night_audit" model="ir.cron">
            <field name="name">ResortPro: Night Audit (Daily Revenue Close)</field>
            <field name="model_id" ref="model_night_audit"/>
            <field name="state">code</field>
            <field name="code">model.action_run_night_audit()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall">False</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>
